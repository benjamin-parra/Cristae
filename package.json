{
  "name": "cristae",
  "version": "0.13.4",
  "type": "module",
  "description": "Librería de mapas WebGL + tabla virtual sobre un núcleo de datos reactivo compartido. Tres entry points desacoplados (core / table / map); table y map nunca se importan entre sí.",
  "keywords": [
    "web-components",
    "widgets",
    "real-time",
    "webgl",
    "leaflet",
    "glify",
    "virtual-table",
    "reactive",
    "map"
  ],
  "license": "MIT",
  "author": "Benjamin Parra",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/benjamin-parra/Cristae.git"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "lint": "eslint src build.mjs",
    "build": "node build.mjs",
    "test": "node --test"
  },
  "sideEffects": [
    "./src/index.js",
    "./src/table/index.js"
  ],
  "exports": {
    "./core": {
      "types": "./types/core.d.ts",
      "default": "./src/data/index.js"
    },
    "./table": {
      "types": "./types/table.d.ts",
      "default": "./src/table/index.js"
    },
    "./map": {
      "types": "./types/map.d.ts",
      "default": "./src/index.js"
    },
    "./grammar": {
      "types": "./types/grammar.d.ts",
      "default": "./src/grammar/index.js"
    },
    "./package.json": "./package.json"
  },
  "peerDependencies": {
    "leaflet": "^1.9.4",
    "lit": "^3.3.3"
  },
  "dependencies": {
    "leaflet.glify": "^3.3.1",
    "supercluster": "^8.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "eslint": "^9.13.0",
    "globals": "^15.11.0",
    "vite": "^7.3.3"
  },
  "files": [
    "src",
    "types",
    "docs",
    "SKILL.md",
    "MODELO.md",
    "SPECS.md",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "build.mjs"
  ]
}
