{
  "name": "cristae",
  "version": "0.1.0",
  "type": "module",
  "description": "Librería de mapas WebGL + tabla virtual sobre un núcleo de datos reactivo compartido. Tres entry points desacoplados (core / table / map); table y map nunca se importan entre sí.",
  "keywords": ["web-components", "widgets", "real-time", "webgl", "leaflet", "glify", "virtual-table", "reactive", "map"],
  "license": "MIT",
  "author": "Benjamin Parra",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/benjamin-parra/Cristae.git"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "lint": "eslint src build.mjs",
    "build": "node build.mjs",
    "test": "node test/grammar.test.mjs"
  },
  "sideEffects": ["./src/index.js", "./src/table/index.js"],
  "exports": {
    "./core": "./src/data/index.js",
    "./table": "./src/table/index.js",
    "./map": "./src/index.js",
    "./grammar": "./src/grammar/index.js",
    "./package.json": "./package.json"
  },
  "peerDependencies": {
    "leaflet": "^1.9.4",
    "lit": "^3.3.3"
  },
  "dependencies": {
    "leaflet.glify": "^3.3.1",
    "supercluster": "^8.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "eslint": "^9.13.0",
    "globals": "^15.11.0",
    "vite": "^7.3.3"
  },
  "files": ["src", "docs", "SKILL.md", "MODELO.md", "SPECS.md", "README.md", "CHANGELOG.md", "LICENSE", "build.mjs"]
}
